{
	"name": "immich-deck",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Stream Deck plugin: headless Immich server panel",
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.immichdeck.panel\""
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.0.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^28.0.0",
		"@rollup/plugin-node-resolve": "^15.3.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.1.0",
		"@types/node": "^24.0.0",
		"rollup": "^4.22.0",
		"tslib": "^2.7.0",
		"typescript": "^5.6.0"
	}
}
